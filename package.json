{
  "name": "@alchemaize/forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Direct AWS infrastructure management. No stacks. No state files. No surprises.",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "forge": "./bin/forge.mjs"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewayv2": "^3.700.0",
    "@aws-sdk/client-cloudformation": "^3.1037.0",
    "@aws-sdk/client-cloudfront": "^3.1037.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-ec2": "^3.700.0",
    "@aws-sdk/client-ecr": "^3.700.0",
    "@aws-sdk/client-ecs": "^3.700.0",
    "@aws-sdk/client-elasticache": "^3.1037.0",
    "@aws-sdk/client-eventbridge": "^3.700.0",
    "@aws-sdk/client-iam": "^3.700.0",
    "@aws-sdk/client-kms": "^3.1038.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-rds": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-sfn": "^3.1037.0",
    "@aws-sdk/client-sns": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.1037.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.700.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
